<h1>{{title}}</h1>

{{#if products.length}}
  <div>
    {{#each products}}
      <div style="border: 1px solid #ccc; padding: 12px; margin-bottom: 12px;">
        <h2>{{this.title}}</h2>
        <p>{{this.description}}</p>
        <p><strong>Precio:</strong> ${{this.price}}</p>
        <img src="{{this.thumbnail}}" alt="{{this.title}}" width="200" />
      </div>
    {{/each}}
  </div>
{{else}}
  <p>No hay productos disponibles.</p>
{{/if}}